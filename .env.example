# ============================================
# WORKSHOPPortal — Environment Variables
# ============================================
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to GitHub

# ── Database (PostgreSQL on VPS) ──────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://tenportal:YOUR_PASSWORD_HERE@187.77.59.230:54321/tenportal"

# ── Authentication ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="YOUR_64_CHAR_SECRET_HERE"

# ── App URL (used for CORS & redirects) ──────────────────────
# Local dev: http://localhost:3000
# Production: https://mentesucesso-landing.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── MinIO / Object Storage (optional) ────────────────────────
# Used for file uploads (thumbnails, PDFs, etc.)
MINIO_ENDPOINT="187.77.59.230"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="YOUR_MINIO_ACCESS_KEY"
MINIO_SECRET_KEY="YOUR_MINIO_SECRET_KEY"
MINIO_BUCKET="tenportal"
MINIO_URL="https://tenportal-files.alvarobiano.com.br"